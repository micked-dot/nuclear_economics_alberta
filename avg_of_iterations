#!/usr/bin/env python3
import argparse
import numpy as np

from original import simulate_single_scenario


def run_iterations(iterations: int, seed: int | None = None) -> dict:
    rng = np.random.default_rng(seed)
    ccgt_npvs = []
    nuclear_npvs = []
    avg_gas_prices = []
    avg_electricity_prices = []

    for _ in range(iterations):
        metrics = simulate_single_scenario(rng=rng)
        ccgt_npvs.append(metrics['ccgt_npv'])
        nuclear_npvs.append(metrics['nuclear_npv'])
        avg_gas_prices.append(metrics['avg_gas_price'])
        avg_electricity_prices.append(metrics['avg_electricity_price'])

    return {
        'iterations': iterations,
        'ccgt_npvs': np.array(ccgt_npvs),
        'nuclear_npvs': np.array(nuclear_npvs),
        'avg_gas_prices': np.array(avg_gas_prices),
        'avg_electricity_prices': np.array(avg_electricity_prices),
    }


def print_aggregated_results(results: dict) -> None:
    print(f'Iterations: {results["iterations"]}')
    print(f'Average CCGT NPV: {results["ccgt_npvs"].mean():,.0f} (std: {results["ccgt_npvs"].std():,.0f})')
    print(f'Average Nuclear NPV: {results["nuclear_npvs"].mean():,.0f} (std: {results["nuclear_npvs"].std():,.0f})')
    print(f'Average Gas Price: {results["avg_gas_prices"].mean():.4f} (std: {results["avg_gas_prices"].std():.4f})')
    print(f'Average Electricity Price: {results["avg_electricity_prices"].mean():.4f} (std: {results["avg_electricity_prices"].std():.4f})')


def main() -> None:
    parser = argparse.ArgumentParser(description='Run aggregate scenario results across many random iterations.')
    parser.add_argument('-i', '--iterations', type=int, default=100, help='Number of stochastic model iterations.')
    parser.add_argument('-s','--seed', type=int, default=None, help='Optional seed for repeatable results.')
    args = parser.parse_args()

    results = run_iterations(args.iterations, args.seed)
    print_aggregated_results(results)


if __name__ == '__main__':
    main()